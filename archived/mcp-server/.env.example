# MCP Server Configuration
# Copy this file to .env and customize for your environment

# Environment (development, testing, production)
ENVIRONMENT=development

# Database URL - will be automatically set based on environment unless overridden
# For overriding the database URL directly:
# DATABASE_URL=postgresql://user:password@localhost:5432/crm-gidital-fte

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Authentication token for MCP server (optional)
MCP_SERVER_TOKEN=your-secret-token-here

# Rate limiting settings
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60