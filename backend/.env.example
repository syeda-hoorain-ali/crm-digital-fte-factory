# ==================================================
# Database Configuration
# ==================================================
DATABASE_URL=postgresql://user:password@localhost:5432/crm_digital_fte

# ==================================================
# Gemini API Configuration (Required)
# ==================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ==================================================
# Gmail Configuration (Production)
# ==================================================
GMAIL_SERVICE_ACCOUNT_PATH=/path/to/service-account-credentials.json
GMAIL_SUPPORT_CREDENTIALS_PATH=/path/to/support-account-credentials.json
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications
GMAIL_SUPPORT_ADDRESS=support@example.com
GMAIL_WEBHOOK_SECRET=your-webhook-secret-here
GCP_PROJECT_ID=your-gcp-project-id

# ==================================================
# Gmail E2E Testing (Sender Account)
# ==================================================
# These credentials are for the test account that sends emails
# (simulates a customer sending emails to your support inbox)
GMAIL_TEST_CREDENTIALS_PATH=/path/to/test-sender-credentials.json
GMAIL_TEST_ACCOUNT_EMAIL=test-sender@example.com

# ==================================================
# Twilio WhatsApp Configuration
# ==================================================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_APP_NUMBER=whatsapp:+141234567890
TWILIO_WEBHOOK_SECRET=your-twilio-webhook-secret

# E2E Test Configuration
TWILIO_TEST_ACCOUNT_SID=your-account-sid      # Same as above for testing
TWILIO_TEST_AUTH_TOKEN=your-auth-token        # Same as above for testing
TWILIO_TEST_FROM_NUMBER=whatsapp:+9234567890  # Test sender (sandbox number)

# ==================================================
# Kafka Configuration
# ==================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=customer-intake

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
