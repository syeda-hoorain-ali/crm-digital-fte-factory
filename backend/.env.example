# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection string for Neon database
# Format: postgresql+asyncpg://user:password@host:port/database
# Note: Use postgresql+asyncpg:// for async SQLAlchemy support
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-xxx-xxx.region.aws.neon.tech/neondb

# =============================================================================
# LLM Provider Configuration (Gemini, Groq, OpenAI-compatible APIs)
# =============================================================================

# API key for LLM provider
# - Gemini: Get from https://aistudio.google.com/apikey
# - Groq: Get from https://console.groq.com/keys
# - OpenAI: Get from https://platform.openai.com/api-keys
GEMINI_API_KEY=your-api-key-here

# Base URL for LLM provider (OpenAI-compatible endpoint)
# - Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
# - Groq: https://api.groq.com/openai/v1/
# - OpenAI: https://api.openai.com/v1/
# - Other OpenAI-compatible APIs: Use their base URL
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# =============================================================================
# Embedding Configuration (Optional)
# =============================================================================

# Embedding model for semantic search and knowledge base
# Default: sentence-transformers/all-MiniLM-L6-v2 (FastEmbed)
# Other options: BAAI/bge-small-en-v1.5, sentence-transformers/all-mpnet-base-v2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding vector dimension (must match the model)
# all-MiniLM-L6-v2: 384
# all-mpnet-base-v2: 768
# bge-small-en-v1.5: 384
EMBEDDING_DIMENSION=384

# =============================================================================
# Application Configuration
# =============================================================================

# Application environment
# Options: development, staging, production
ENVIRONMENT=development

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# API Configuration (Optional)
# =============================================================================

# API server host (default: 0.0.0.0)
# API_HOST=0.0.0.0

# API server port (default: 8000)
# API_PORT=8000

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Agent Configuration (Optional)
# =============================================================================

# LLM model for agent operations (default: gemini-2.5-flash)
# AGENT_MODEL=gemini-2.5-flash

# Maximum tokens for agent responses (default: 4096)
# AGENT_MAX_TOKENS=4096

# Agent temperature for response generation (default: 0.7)
# AGENT_TEMPERATURE=0.7

# =============================================================================
# Database Connection Pool (Optional)
# =============================================================================

# Maximum number of database connections in the pool (default: 10)
# DB_POOL_SIZE=10

# Maximum overflow connections beyond pool_size (default: 20)
# DB_MAX_OVERFLOW=20

# Connection timeout in seconds (default: 30)
# DB_POOL_TIMEOUT=30

# =============================================================================
# Knowledge Base Configuration (Optional)
# =============================================================================

# Number of knowledge base results to return (default: 5)
# KB_SEARCH_LIMIT=5

# Minimum similarity score for knowledge base results (default: 0.7)
# KB_MIN_SIMILARITY=0.7

# =============================================================================
# Observability Configuration (Optional)
# =============================================================================

# Enable detailed request/response logging (default: false)
# ENABLE_DEBUG_LOGGING=false

# Enable performance metrics collection (default: true)
# ENABLE_METRICS=true

# Enable distributed tracing (default: false)
# ENABLE_TRACING=false
